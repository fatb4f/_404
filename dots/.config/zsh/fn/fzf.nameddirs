fzf.nameddirs() {
  local mode="${1:-cd}"
  local path
  local fzf_bin="${commands[fzf]:-$HOME/.local/bin/fzf}"

  if [[ ! -x "$fzf_bin" ]]; then
    print -u2 'fzf.nameddirs: fzf not found'
    return 127
  fi

  path="$(
    print -rl -- "${(@k)nameddirs}" |
      "$fzf_bin" --prompt='dir > '
  )" || return

  path="${nameddirs[$path]}"

  case "$mode" in
    cd) cd "$path" ;;
    br) br "$path" ;;
    *)  return 1 ;;
  esac
}
