# generated by _404 codex domain projection
# authority: init/src/schema/codex.cue + domains.d/codex/codex.json

profile = "@CODEX_PROFILE@"
approval_policy = "never"
sandbox_mode = "workspace-write"
web_search = "cached"
allow_login_shell = false

[features]
codex_hooks = true
shell_tool = true
shell_snapshot = true

[profiles.@CODEX_PROFILE@]
approval_policy = "never"
sandbox_mode = "workspace-write"
web_search = "cached"
allow_login_shell = false

[profiles.@CODEX_PROFILE@.shell_environment_policy]
inherit = "core"
include_only = [
  "HOME",
  "PATH",
  "SHELL",
  "TERM",
  "USER",
  "LOGNAME",
  "PWD",
  "LANG",
  "LC_*",
  "XDG_CONFIG_HOME",
  "XDG_DATA_HOME",
  "XDG_STATE_HOME",
  "XDG_CACHE_HOME",
  "CODEX_HOME",
  "DOTS_HOME",
  "DOTS_PROFILE",
  "DOTS_AGENT_SURFACE",
]
exclude = ["*TOKEN*", "*SECRET*", "*KEY*", "*PASSWORD*"]
experimental_use_profile = false
ignore_default_excludes = false
set = { DOTS_PROFILE = "@CODEX_PROFILE@", DOTS_AGENT_SURFACE = "codex" }

[[hooks.SessionStart]]
matcher = "startup|resume|clear"

[[hooks.SessionStart.hooks]]
type = "command"
command = "sh -c 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/hooks/session-init.sh\"'"
timeout = 10
statusMessage = "Capturing Codex session frame"

[[hooks.PreToolUse]]
matcher = "^Bash$"

[[hooks.PreToolUse.hooks]]
type = "command"
command = "sh -c 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/hooks/pre-tool-use.sh\"'"
timeout = 10
statusMessage = "Checking Bash command"

[[hooks.PostToolUse]]
matcher = "^Bash$"

[[hooks.PostToolUse.hooks]]
type = "command"
command = "sh -c 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/hooks/post-tool-use.sh\"'"
timeout = 10
statusMessage = "Recording Bash result"

[[hooks.Stop]]

[[hooks.Stop.hooks]]
type = "command"
command = "sh -c 'exec \"${CODEX_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/codex}/hooks/stop.sh\"'"
timeout = 10
statusMessage = "Refreshing Codex context frame"
