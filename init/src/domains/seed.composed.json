{
  "roots": {
    "dots_repo": "src",
    "dots_dir": "dots",
    "dots": "$HOME/$DOTS_REPO/$DOTS_DIR",
    "xdg_config": "$DOTS_HOME/.config",
    "xdg_data": "$DOTS_HOME/.local/share",
    "xdg_opt": "$DOTS_HOME/.local/opt",
    "xdg_state": "$HOME/.local/state",
    "xdg_cache": "$HOME/.cache",
    "tool_path": "$HOME/.local/bin"
  },
  "domains": [
    {
      "id": "0-noninteractive-shell",
      "namespace": "NONINTERACTIVE_SHELL",
      "stage": "00-shell",
      "ring": "substrate",
      "provider": "domain_local",
      "bins": [],
      "requires": [
        "tool.sh"
      ],
      "provides": [
        "domain.generated/init/noninteractive-shell",
        "shell.noninteractive",
        "shell.bootstrap.ready"
      ],
      "extra_env": {
        "BOOTSTRAP_STATE": "$XDG_STATE_HOME/_404/bootstrap",
        "STAGE_ROOT": "$NONINTERACTIVE_SHELL_PREFIX"
      },
      "init_sources": [
        "require.sh",
        "env.sh",
        "path.sh"
      ],
      "files": [
        {
          "source": "files/env.sh",
          "target": "$DOMAIN_PREFIX/env.sh",
          "mode": "0644"
        },
        {
          "source": "files/init.sh",
          "target": "$DOMAIN_PREFIX/init.sh",
          "mode": "0644"
        },
        {
          "source": "files/env-loader.sh",
          "target": "$XDG_CONFIG_HOME/_404/env.sh",
          "mode": "0644"
        },
        {
          "source": "files/bash_profile",
          "target": "$HOME/.bash_profile",
          "mode": "0644"
        },
        {
          "source": "files/bashrc",
          "target": "$HOME/.bashrc",
          "mode": "0644"
        },
        {
          "source": "files/path.sh",
          "target": "$DOMAIN_PREFIX/path.sh",
          "mode": "0644"
        },
        {
          "source": "files/require.sh",
          "target": "$DOMAIN_PREFIX/require.sh",
          "mode": "0644"
        }
      ],
      "checks": [
        {
          "id": "stage-ready",
          "command": "test -f $XDG_STATE_HOME/_404/bootstrap/00-shell.ready",
          "severity": "fatal"
        },
        {
          "id": "files-present",
          "command": "test -f $DOMAIN_PREFIX/init.sh && test -f $DOMAIN_PREFIX/env.sh && test -f $DOMAIN_PREFIX/path.sh && test -f $DOMAIN_PREFIX/require.sh && test -f $XDG_CONFIG_HOME/_404/env.sh && test -f $HOME/.bash_profile && test -f $HOME/.bashrc",
          "severity": "fatal"
        },
        {
          "id": "shell-parse",
          "command": "sh -n $DOMAIN_PREFIX/init.sh $DOMAIN_PREFIX/env.sh $DOMAIN_PREFIX/path.sh $DOMAIN_PREFIX/require.sh $XDG_CONFIG_HOME/_404/env.sh $HOME/.bash_profile $HOME/.bashrc",
          "severity": "fatal"
        },
        {
          "id": "bash-available",
          "command": "command -v bash >/dev/null 2>&1",
          "severity": "fatal"
        },
        {
          "id": "env-loader-parse",
          "command": "test -f $XDG_CONFIG_HOME/_404/env.sh && sh -n $XDG_CONFIG_HOME/_404/env.sh",
          "severity": "fatal"
        },
        {
          "id": "bash_profile-parse",
          "command": "test -f $HOME/.bash_profile && sh -n $HOME/.bash_profile",
          "severity": "fatal"
        },
        {
          "id": "bashrc-parse",
          "command": "test -f $HOME/.bashrc && sh -n $HOME/.bashrc",
          "severity": "fatal"
        }
      ],
      "output_dir": "generated/init/noninteractive-shell"
    },
    {
      "id": "0-interactive-shell",
      "namespace": "INTERACTIVE_SHELL",
      "stage": "interactive-shell",
      "ring": "substrate",
      "provider": "domain_local",
      "bins": [],
      "requires": [
        "tool.zsh",
        "shell.bootstrap.ready"
      ],
      "provides": [
        "domain.generated/init/interactive-shell",
        "shell.interactive.ready"
      ],
      "init_sources": [
        "env.sh"
      ],
      "files": [
        {
          "source": "files/env.sh",
          "target": "$DOMAIN_PREFIX/env.sh",
          "mode": "0644"
        },
        {
          "source": "files/init.sh",
          "target": "$DOMAIN_PREFIX/init.sh",
          "mode": "0644"
        },
        {
          "source": "files/zshenv",
          "target": "$HOME/.zshenv",
          "mode": "0644"
        },
        {
          "source": "files/zshrc",
          "target": "$HOME/.zshrc",
          "mode": "0644"
        }
      ],
      "checks": [
        {
          "id": "zsh-available",
          "command": "command -v zsh >/dev/null 2>&1",
          "severity": "fatal"
        },
        {
          "id": "zshenv-parse",
          "command": "test -f $HOME/.zshenv && sh -n $HOME/.zshenv",
          "severity": "fatal"
        },
        {
          "id": "zshrc-parse",
          "command": "test -f $HOME/.zshrc && sh -n $HOME/.zshrc",
          "severity": "fatal"
        },
        {
          "id": "stage-ready",
          "command": "test -f $XDG_STATE_HOME/_404/bootstrap/interactive-shell.ready",
          "severity": "degraded"
        }
      ],
      "output_dir": "generated/init/interactive-shell"
    },
    {
      "id": "1-terminal",
