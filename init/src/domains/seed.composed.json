      ]
    },
    {
      "id": "go",
      "namespace": "GO",
      "stage": "40-tools",
      "ring": "workflow",
      "provider": "host_pkg",
      "output_dir": "generated/tools/go",
      "bins": [
        "go",
        "gofmt"
      ],
      "provides": [
        "domain.generated/tools/go",
        "tool.go",
        "tool.gofmt"
      ],
      "deps": {
        "native": {
          "mode": "pkg_metadata",
          "packages": {
            "arch": "go",
            "debian": "golang-go"
          },
          "include": [
            "depends",
            "predepends"
          ],
          "features": [
            "recommends",
            "optional"
          ]
        }
      },
      "files": [
        {
          "source": "files/env.sh",
          "target": "$DOMAIN_PREFIX/env.sh",
          "mode": "0644"
        },
        {
          "source": "files/init.sh",
          "target": "$DOMAIN_PREFIX/init.sh",
          "mode": "0644"
        }
      ],
      "checks": [
        {
          "id": "go-available",
          "command": "command -v go >/dev/null 2>&1",
          "severity": "fatal"
        },
        {
          "id": "gofmt-available",
          "command": "command -v gofmt >/dev/null 2>&1",
          "severity": "fatal"
        },
        {
          "id": "go-env-probe",
          "command": "go env GOPATH GOBIN GOMODCACHE >/dev/null 2>&1",
          "severity": "fatal"
        }
      ],
      "template_values": {
        "DOMAIN_ENV_EXTRA": ": \"${GOPATH:=$HOME/go}\"\n: \"${GOBIN:=$GOPATH/bin}\"\nif command -v _path_prepend >/dev/null 2>&1; then\n  _path_prepend \"$GOBIN\"\nelse\n  case \":$PATH:\" in\n    *\":$GOBIN:\"*) ;;\n    *) PATH=\"$GOBIN${PATH:+:$PATH}\"; export PATH ;;\n  esac\nfi\nexport GOPATH GOBIN PATH"
      }
    }
  ]
}
