set shell := ["sh", "-eu", "-c"]

python := "python3"
domains := "generated/init/noninteractive-shell generated/init/interactive-shell generated/init/term/kitty generated/postinit/codex generated/tools/go generated/tools/cue"

# Compose optional domains.d fragments into a materialized seed.
compose-seed:
	{{python}} src/gen/compose_seed.py --root . --seed src/domains/seed.json --fragments domains.d --out src/domains/seed.composed.json

# Regenerate domain artifacts from the bootstrap seed.
gen: compose-seed
	{{python}} src/gen/domain.py --root . --seed src/domains/seed.composed.json

# Parse generated shell and compile generator.
check-generated:
	{{python}} -m py_compile src/gen/domain.py src/gen/compose_seed.py
	find generated src -path './.git' -prune -o \( -name '*.sh' -o -name 'zshenv' -o -name 'zshrc' -o -name 'bash_profile' -o -name 'bashrc' -o -name '_404-codex' \) -print | xargs -r sh -n
	sh -n generated/postinit/codex/files/hooks/session-init.sh generated/postinit/codex/files/hooks/pre-tool-use.sh generated/postinit/codex/files/hooks/post-tool-use.sh generated/postinit/codex/files/hooks/stop.sh generated/postinit/codex/files/bin/_404-codex dots/.config/codex/hooks/session-init.sh dots/.config/codex/hooks/pre-tool-use.sh dots/.config/codex/hooks/post-tool-use.sh dots/.config/codex/hooks/stop.sh dots/.local/bin/_404-codex
	bash -n generated/init/noninteractive-shell/files/bash_profile generated/init/noninteractive-shell/files/bashrc
	{{python}} -c 'import pathlib, tomllib; tomllib.loads(pathlib.Path("generated/postinit/codex/files/config.toml").read_text())'

# Validate that generated artifacts match the seed.
regen-check: compose-seed
	{{python}} src/gen/domain.py --root . --seed src/domains/seed.composed.json
	git diff --exit-code -- generated src/domains/seed.composed.json

# Dry-run install in declared domain order.
dry-run: compose-seed
	for d in {{domains}}; do DOMAIN_DRY_RUN=1 sh "$$d/install.sh"; done

# Run read-only checks. Some may report degraded until installed.
doctor: compose-seed
	for d in {{domains}}; do sh "$$d/check.sh" || true; done
