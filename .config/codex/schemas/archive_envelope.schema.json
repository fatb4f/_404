{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Archive envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "bundle_role",
    "archive_format",
    "archive_name",
    "contents"
  ],
  "properties": {
    "kind": {
      "const": "bundle_envelope.v1"
    },
    "bundle_role": {
      "type": "string",
      "enum": [
        "request",
        "response"
      ]
    },
    "archive_format": {
      "type": "string",
      "enum": [
        "tar_gz"
      ]
    },
    "archive_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+\\.tar\\.gz$"
    },
    "contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
