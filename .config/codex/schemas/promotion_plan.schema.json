{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Promotion plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "bounded_batch_id",
    "promotion_mode",
    "target_branch",
    "required_evidence_refs",
    "post_promotion_gates"
  ],
  "properties": {
    "kind": {
      "const": "promotion_plan.v1"
    },
    "bounded_batch_id": {
      "type": "string",
      "minLength": 1
    },
    "promotion_mode": {
      "type": "string",
      "enum": [
        "patch_promotion",
        "curated_commit"
      ]
    },
    "target_branch": {
      "type": "string",
      "minLength": 1
    },
    "required_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "post_promotion_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_mode": {
      "type": "string"
    }
  }
}
