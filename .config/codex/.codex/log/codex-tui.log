+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
+export REPO_ROOT="$repo_root"
+INIT_D="$repo_root/init.sh.d"
+
+if [[ ! -d "$INIT_D" ]]; then
+  echo "error: init directory '$INIT_D' not found" >&2
+  exit 1
+fi
+
+declare -a init_steps
+while IFS= read -r step; do
+  if [[ -f "$step" && -x "$step" && ! "$step" =~ "##" && ! "$step" =~ ~$ ]]; then
+    init_steps+=("$step")
+  fi
+done < <(find -L "$INIT_D" -type f | sort)
+
+for step in "${init_steps[@]}"; do
+  # shellcheck source=/dev/null
+  . "$step"
+done
*** Update File: ../init.sh.d/00-preflight.sh
@@
-REPO_ROOT="${_404_REPO_ROOT:-${HOME}/.local/share/opt/_404}"
+: "${REPO_ROOT:?REPO_ROOT must be set by init.sh}"
