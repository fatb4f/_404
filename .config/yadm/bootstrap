#!/usr/bin/env bash
set -euo pipefail

: "${HOME:?HOME is required}"
: "${XDG_CONFIG_HOME:=$HOME/.config}"

shell_env="$XDG_CONFIG_HOME/shell/load-env.sh"
bootstrap_dir="$XDG_CONFIG_HOME/yadm/bootstrap.d"

if [[ -r "$shell_env" ]]; then
  # shellcheck source=/dev/null
  . "$shell_env"
fi

for fragment in "$bootstrap_dir"/*.sh; do
  [[ -f "$fragment" ]] || continue
  # shellcheck source=/dev/null
  . "$fragment"
done
