# :command.usage
dotctl_usage() {
  printf "dotctl - Dotfiles lifecycle adapter\n\n"

  printf "%s\n" "Usage:"
  printf "  dotctl COMMAND\n"
  printf "  dotctl [COMMAND] --help | -h\n"
  printf "  dotctl --version | -v\n"
  echo
  # :command.usage_commands
  printf "%s\n" "Commands:"
  printf "  %s   Run the strict CUE-backed dotfiles audit\n" "audit    "
  printf "  %s   Run shell, bootstrap, audit, and yadm checks\n" "check    "
  printf "  %s   Run yadm bootstrap\n" "bootstrap"
  printf "  %s   Show yadm repository status\n" "status   "
  printf "  %s   Run the phase-0 provisioning handoff\n" "provision"
  echo

  # :command.long_usage
  if [[ -n "$long_usage" ]]; then
    # :command.usage_options
    printf "%s\n" "Options:"

    # :command.usage_fixed_flags
    printf "  %s\n" "--help, -h"
    printf "    Show this help\n"
    echo
    printf "  %s\n" "--version, -v"
    printf "    Show version number\n"
    echo

  fi
}

