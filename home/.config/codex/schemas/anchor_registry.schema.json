{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Anchor registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "@context",
    "@id",
    "@type",
    "kind",
    "anchors"
  ],
  "properties": {
    "@context": {
      "type": "string"
    },
    "@id": {
      "type": "string"
    },
    "@type": {
      "const": "AnchorRegistry"
    },
    "kind": {
      "const": "anchor_registry.v1"
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
