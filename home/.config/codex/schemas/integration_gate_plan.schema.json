{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Integration gate plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "bounded_batch_id",
    "runs_on",
    "required_checks",
    "required_artifacts"
  ],
  "properties": {
    "kind": {
      "const": "integration_gate_plan.v1"
    },
    "bounded_batch_id": {
      "type": "string",
      "minLength": 1
    },
    "runs_on": {
      "type": "string",
      "enum": [
        "integration_worktree",
        "main",
        "both"
      ]
    },
    "required_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bounded_batch_expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "pass_effect": {
      "type": "string"
    },
    "fail_effect": {
      "type": "string"
    }
  }
}
