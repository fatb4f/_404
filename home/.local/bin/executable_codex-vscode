#!/usr/bin/env bash
set -euo pipefail

export CODEX_HOME="${CODEX_HOME:-/home/_404/.config/codex}"
export CODEX_STATE="${CODEX_STATE:-/home/_404/.local/state/codex}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-/home/_404/.config}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-/home/_404/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/home/_404/.cache}"
export PRJROOT="${PRJROOT:-/home/_404/.local/share/src}"

mkdir -p "$XDG_CACHE_HOME/codex"

# Pre-launch refresh should be immediate.
/home/_404/.local/bin/codex-refresh-context >/dev/null 2>&1 || true

# Ensure the GitHub release-backed codex binary exists.
/home/_404/.local/bin/codex-install >/dev/null 2>&1 || true

codex_bin="${CODEX_BIN:-$HOME/.local/bin/codex}"
if [[ ! -x "$codex_bin" ]]; then
  printf 'codex-vscode: missing codex binary at %s\n' "$codex_bin" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  exec "$codex_bin" \
    --dangerously-bypass-approvals-and-sandbox \
    resume \
    --cd "$PRJROOT" \
    --last
fi

exec "$codex_bin" "$@"
