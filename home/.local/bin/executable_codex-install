#!/usr/bin/env bash
set -euo pipefail

install_root="${CODEX_INSTALL_ROOT:-$HOME/.local/opt/codex}"
install_bin_dir="${install_root}/bin"
install_bin="${install_bin_dir}/codex"
asset_name="${CODEX_RELEASE_ASSET:-codex-x86_64-unknown-linux-musl.tar.gz}"
repo="${CODEX_RELEASE_REPO:-openai/codex}"

if [[ -x "$install_bin" ]]; then
  exit 0
fi

command -v gh >/dev/null 2>&1 || {
  printf 'codex-install: gh is required to download the release\n' >&2
  exit 1
}

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

gh release download -R "$repo" --pattern "$asset_name" --dir "$tmpdir" >/dev/null

tarball="${tmpdir}/${asset_name}"
if [[ ! -f "$tarball" ]]; then
  printf 'codex-install: missing downloaded asset %s\n' "$tarball" >&2
  exit 1
fi

tmp_extract="${tmpdir}/extract"
mkdir -p "$tmp_extract"
tar -xzf "$tarball" -C "$tmp_extract"

mkdir -p "$install_bin_dir"
install -m 0755 "${tmp_extract}/codex-x86_64-unknown-linux-musl" "$install_bin"
ln -sf "$install_bin" "$HOME/.local/bin/codex"
