#!/usr/bin/env bash
set -euo pipefail

out_dir="${HOME}/.local/state/broot"
out_file="${out_dir}/current-skin.hjson"

mkdir -p "${out_dir}"

need() {
  local name="$1"
  if [[ -z "${!name:-}" ]]; then
    printf 'tinty-broot-hook: missing env var %s\n' "$name" >&2
    exit 1
  fi
}

hex_to_rgb() {
  local hex="${1#\#}"
  hex="${hex//\//}"
  printf 'rgb(%d, %d, %d)' "$((16#${hex:0:2}))" "$((16#${hex:2:2}))" "$((16#${hex:4:2}))"
}

chan() {
  local base="${1^^}"
  local channel="${2^^}"
  local rv="TINTY_SCHEME_PALETTE_${base}_RGB_R"
  local gv="TINTY_SCHEME_PALETTE_${base}_RGB_G"
  local bv="TINTY_SCHEME_PALETTE_${base}_RGB_B"
  local hx="BASE24_COLOR_${base#BASE}_HEX"

  if [[ -n "${!rv:-}" && -n "${!gv:-}" && -n "${!bv:-}" ]]; then
    case "$channel" in
      R) printf '%s' "${!rv}" ;;
      G) printf '%s' "${!gv}" ;;
      B) printf '%s' "${!bv}" ;;
      *) return 1 ;;
    esac
    return
  fi

  if [[ -n "${!hx:-}" ]]; then
    local hex="${!hx}"
    hex="${hex#\#}"
    hex="${hex//\//}"
    case "$channel" in
      R) printf '%d' "$((16#${hex:0:2}))" ;;
      G) printf '%d' "$((16#${hex:2:2}))" ;;
      B) printf '%d' "$((16#${hex:4:2}))" ;;
      *) return 1 ;;
    esac
    return
  fi

  need "$rv"
  need "$gv"
  need "$bv"
}

rgb_base() {
  local base="${1^^}"
  printf 'rgb(%s, %s, %s)' "$(chan "$base" R)" "$(chan "$base" G)" "$(chan "$base" B)"
}

mix_base() {
  local a="${1^^}"
  local b="${2^^}"
  local wa="${3}"
  local wb=$((100 - wa))
  local ar ag ab br bg bb

  ar="$(chan "$a" R)"; ag="$(chan "$a" G)"; ab="$(chan "$a" B)"
  br="$(chan "$b" R)"; bg="$(chan "$b" G)"; bb="$(chan "$b" B)"

  printf 'rgb(%s, %s, %s)' \
    $(( (ar * wa + br * wb) / 100 )) \
    $(( (ag * wa + bg * wb) / 100 )) \
    $(( (ab * wa + bb * wb) / 100 ))
}

is_light_variant() {
  case "${TINTY_SCHEME_VARIANT:-}" in
    *light*|*Light*|LIGHT) return 0 ;;
    *) return 1 ;;
  esac
}

inactive_fg() {
  local base="${1^^}"
  mix_base "$base" BASE04 45
}

inactive_accent() {
  local base="${1^^}"
  mix_base "$base" BASE04 55
}

inactive_bg() {
  local base="${1^^}"
  if is_light_variant; then
    mix_base "$base" BASE01 92
  else
    mix_base "$base" BASE02 90
  fi
}

scheme_id="${TINTY_SCHEME_ID:-unknown}"
scheme_variant="${TINTY_SCHEME_VARIANT:-unknown}"
scheme_operation="${TINTY_THEME_OPERATION:-unknown}"

cat >"${out_file}" <<EOF
// generated by tinty-broot-hook
// scheme: ${scheme_id}
// variant: ${scheme_variant}
// operation: ${scheme_operation}

skin: {
    default: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    tree: $(rgb_base BASE02) None / $(inactive_fg BASE02) None
    parent: $(rgb_base BASE06) None / $(inactive_fg BASE06) None Italic
    file: $(rgb_base BASE04) None / $(inactive_fg BASE04) None
    directory: $(rgb_base BASE0D) None Bold / $(inactive_accent BASE0D) None
    exe: $(rgb_base BASE0B) None / $(inactive_accent BASE0B) None
    link: $(rgb_base BASE0E) None / $(inactive_accent BASE0E) None
    pruning: $(rgb_base BASE03) None Italic / $(inactive_fg BASE03) None Italic

    perm__: $(rgb_base BASE04) None / $(inactive_fg BASE04) None
    perm_r: $(rgb_base BASE0C) None / $(inactive_accent BASE0C) None
    perm_w: $(rgb_base BASE0A) None / $(inactive_accent BASE0A) None
    perm_x: $(rgb_base BASE0E) None / $(inactive_accent BASE0E) None
    owner: $(rgb_base BASE0D) None Bold / $(inactive_accent BASE0D) None
    group: $(rgb_base BASE0D) None / $(inactive_accent BASE0D) None

    count: $(rgb_base BASE0C) $(rgb_base BASE01) / $(inactive_accent BASE0C) $(inactive_bg BASE01)
    dates: $(rgb_base BASE03) None / $(inactive_fg BASE03) None
    sparse: $(rgb_base BASE09) None / $(inactive_accent BASE09) None
    content_extract: $(rgb_base BASE0C) None Italic / $(inactive_accent BASE0C) None Italic
    content_match: $(rgb_base BASE0D) None Bold / $(inactive_accent BASE0D) None Bold

    device_id_major: $(rgb_base BASE0D) None / $(inactive_accent BASE0D) None
    device_id_sep: $(rgb_base BASE03) None / $(inactive_fg BASE03) None
    device_id_minor: $(rgb_base BASE0D) None / $(inactive_accent BASE0D) None

    git_branch: $(rgb_base BASE0E) None / $(inactive_accent BASE0E) None
    git_insertions: $(rgb_base BASE0B) None / $(inactive_accent BASE0B) None
    git_deletions: $(rgb_base BASE08) None / $(inactive_accent BASE08) None
    git_status_current: $(rgb_base BASE04) None / $(inactive_fg BASE04) None
    git_status_modified: $(rgb_base BASE0A) None / $(inactive_accent BASE0A) None
    git_status_new: $(rgb_base BASE0B) None Bold / $(inactive_accent BASE0B) None Bold
    git_status_ignored: $(rgb_base BASE03) None / $(inactive_fg BASE03) None
    git_status_conflicted: $(rgb_base BASE08) None / $(inactive_accent BASE08) None
    git_status_other: $(rgb_base BASE09) None / $(inactive_accent BASE09) None

    selected_line: None $(rgb_base BASE01) / None $(inactive_bg BASE01)
    char_match: $(rgb_base BASE0A) None / $(inactive_accent BASE0A) None
    file_error: $(rgb_base BASE08) None / $(inactive_accent BASE08) None

    flag_label: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    flag_value: $(rgb_base BASE09) None Bold / $(inactive_accent BASE09) None Bold
    input: $(rgb_base BASE06) None / $(inactive_fg BASE06) $(inactive_bg BASE01)

    status_error: $(rgb_base BASE00) $(rgb_base BASE08) / $(inactive_fg BASE00) $(inactive_bg BASE08)
    status_job: $(rgb_base BASE0A) $(rgb_base BASE01) / $(inactive_accent BASE0A) $(inactive_bg BASE01)
    status_normal: $(rgb_base BASE05) $(rgb_base BASE01) / $(inactive_fg BASE05) $(inactive_bg BASE01)
    status_italic: $(rgb_base BASE0E) $(rgb_base BASE01) Italic / $(inactive_accent BASE0E) $(inactive_bg BASE01) Italic
    status_bold: $(rgb_base BASE09) $(rgb_base BASE01) Bold / $(inactive_accent BASE09) $(inactive_bg BASE01) Bold
    status_code: $(rgb_base BASE0A) $(rgb_base BASE01) / $(inactive_accent BASE0A) $(inactive_bg BASE01)
    status_ellipsis: $(rgb_base BASE03) $(rgb_base BASE00) / $(inactive_fg BASE03) $(inactive_bg BASE00)

    purpose_normal: $(rgb_base BASE05) $(rgb_base BASE01) / $(inactive_fg BASE05) $(inactive_bg BASE01)
    purpose_italic: $(rgb_base BASE0E) $(rgb_base BASE01) / $(inactive_accent BASE0E) $(inactive_bg BASE01)
    purpose_bold: $(rgb_base BASE09) $(rgb_base BASE01) Bold / $(inactive_accent BASE09) $(inactive_bg BASE01) Bold
    purpose_ellipsis: $(rgb_base BASE05) $(rgb_base BASE01) / $(inactive_fg BASE05) $(inactive_bg BASE01)

    scrollbar_track: $(rgb_base BASE02) None / $(inactive_bg BASE02) None
    scrollbar_thumb: $(rgb_base BASE03) None / $(inactive_fg BASE03) None

    help_paragraph: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    help_bold: $(rgb_base BASE09) None Bold / $(inactive_accent BASE09) None Bold
    help_italic: $(rgb_base BASE0E) None Italic / $(inactive_accent BASE0E) None Italic
    help_code: $(rgb_base BASE0B) $(rgb_base BASE01) / $(inactive_accent BASE0B) $(inactive_bg BASE01)
    help_headers: $(rgb_base BASE0D) None Bold / $(inactive_accent BASE0D) None Bold
    help_table_border: $(rgb_base BASE02) None / $(inactive_fg BASE02) None

    preview_title: $(rgb_base BASE06) $(rgb_base BASE00) / $(inactive_fg BASE06) $(inactive_bg BASE00)
    preview: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    preview_line_number: $(rgb_base BASE03) $(rgb_base BASE00) / $(inactive_fg BASE03) $(inactive_bg BASE00)
    preview_separator: $(rgb_base BASE02) None / $(inactive_fg BASE02) None
    preview_match: None $(rgb_base BASE0A) Bold / None $(inactive_bg BASE0A) Bold

    hex_null: $(rgb_base BASE04) None / $(inactive_fg BASE04) None
    hex_ascii_graphic: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    hex_ascii_whitespace: $(rgb_base BASE03) None / $(inactive_fg BASE03) None
    hex_ascii_other: $(rgb_base BASE09) None / $(inactive_accent BASE09) None
    hex_non_ascii: $(rgb_base BASE08) None / $(inactive_accent BASE08) None

    staging_area_title: $(rgb_base BASE05) None / $(inactive_fg BASE05) None
    mode_command_mark: $(rgb_base BASE05) $(rgb_base BASE0E) Bold / $(inactive_fg BASE05) $(inactive_bg BASE0E) Bold

    good_to_bad_0: $(rgb_base BASE0B)
    good_to_bad_1: $(rgb_base BASE0B)
    good_to_bad_2: $(rgb_base BASE0B)
    good_to_bad_3: $(rgb_base BASE0C)
    good_to_bad_4: $(rgb_base BASE0C)
    good_to_bad_5: $(rgb_base BASE0A)
    good_to_bad_6: $(rgb_base BASE0A)
    good_to_bad_7: $(rgb_base BASE09)
    good_to_bad_8: $(rgb_base BASE08)
    good_to_bad_9: $(rgb_base BASE08)
}
EOF
