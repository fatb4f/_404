#!/usr/bin/env python3
"""FZF tooling for app2unit transient units and launcher-based starts."""

from __future__ import annotations

import argparse
import os
import re
import shlex
import shutil
import subprocess
import sys
from pathlib import Path


def _try(lines_cmd: list[str]) -> str:
    proc = subprocess.run(lines_cmd, check=False, text=True, capture_output=True)
    return proc.stdout if proc.returncode == 0 else ""


def _unescape_systemd_name(value: str) -> str:
    return re.sub(
        r"\\x([0-9A-Fa-f]{2})",
        lambda m: chr(int(m.group(1), 16)),
        value,
    )


def _list_app_units() -> list[dict[str, str]]:
    stdout = _try(
        [
            "systemctl",
            "--user",
            "list-units",
            "--all",
            "--type=service",
            "--no-legend",
            "--plain",
            "--no-pager",
        ]
    )
    units: list[dict[str, str]] = []
    prefix = os.environ.get("APP_UNIT_PREFIX", "app-")
    for raw in stdout.splitlines():
        if not raw.strip():
            continue
        cols = raw.split(None, 4)
        if len(cols) < 4:
            continue
        if len(cols) == 4:
            cols.append("")
        unit, load, active, sub, desc = cols
        if not unit.startswith(prefix) or not unit.endswith(".service"):
            continue
        units.append(
            {
                "unit": unit,
                "load": load,
                "active": active,
                "sub": sub,
                "desc": desc,
                "unit_unescaped": _unescape_systemd_name(unit),
            }
        )
    return units


def _unit_action(action: str, unit: str) -> int:
    if action in {"stop", "restart"}:
        return subprocess.call(["systemctl", "--user", action, unit])
    if action == "status":
        return subprocess.call(["systemctl", "--user", "status", "--no-pager", "--full", unit])
    if action == "status-pager":
        cmd = f"systemctl --user status --no-pager --full {shlex.quote(unit)} | less -R"
        return subprocess.call(["bash", "-lc", cmd])
    if action == "journal-pager":
        cmd = f"journalctl --user -u {shlex.quote(unit)} -n 200 --no-pager | less -R"
        return subprocess.call(["bash", "-lc", cmd])
    print(f"unknown unit action: {action}", file=sys.stderr)
    return 2


def _unit_list_tsv() -> str:
    rows = []
    for u in _list_app_units():
        rows.append("\t".join([u["unit"], u["active"], u["sub"], u["load"], u["desc"]]))
    return "\n".join(rows) + ("\n" if rows else "")


def _unit_fzf(self_path: str) -> int:
    data = _unit_list_tsv()
    if not data.strip():
        print("no loaded app2unit transient services found", file=sys.stderr)
        return 1

    qself = shlex.quote(self_path)
    cmd = [
        "fzf",
        "--delimiter",
        "\t",
        "--with-nth",
        "1,2,3,5",
        "--nth",
        "1,5",
        "--header",
        "ctrl-x stop | ctrl-r restart | enter status | ctrl-j journal",
        "--preview",
        f"{qself} unit --action status " + "{1}",
        "--preview-window",
        "right:60%:wrap",
        "--bind",
        f"ctrl-x:execute-silent({qself} unit --action stop " + "{1})+reload(" + f"{qself} unit --list)",
        "--bind",
        f"ctrl-r:execute-silent({qself} unit --action restart " + "{1})+reload(" + f"{qself} unit --list)",
        "--bind",
        f"enter:execute({qself} unit --action status-pager " + "{1})",
        "--bind",
        f"ctrl-j:execute({qself} unit --action journal-pager " + "{1})",
    ]
    return subprocess.run(cmd, input=data, text=True, check=False).returncode


def _desktop_dirs() -> list[Path]:
    xdg_data_home = Path(os.environ.get("XDG_DATA_HOME", "~/.local/share")).expanduser()
    dirs = [xdg_data_home / "applications", Path("/usr/share/applications")]
    out: list[Path] = []
    for d in dirs:
        if d.exists():
            out.append(d)
    return out


def _parse_desktop(path: Path) -> dict[str, str] | None:
    in_entry = False
    result: dict[str, str] = {"desktop_id": path.name, "path": str(path)}
    try:
        for raw in path.read_text(encoding="utf-8", errors="replace").splitlines():
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("["):
                in_entry = line == "[Desktop Entry]"
                if line.startswith("[Desktop Action"):
                    break
                continue
            if not in_entry or "=" not in line:
                continue
            k, v = line.split("=", 1)
            if k in {"Name", "Exec", "NoDisplay", "Type"}:
                result[k] = v
    except OSError:
        return None

    if result.get("Type") != "Application":
        return None
    if "Exec" not in result:
        return None
    if "app2unit" not in result["Exec"]:
        return None
    if result.get("NoDisplay", "").lower() == "true" and os.environ.get("APP_LAUNCH_FZF_INCLUDE_HIDDEN", "0") != "1":
        return None

    alias = ""
    match = re.search(r"(?:^|\s)-a\s+([A-Za-z0-9._-]+)", result["Exec"])
    if match:
        alias = match.group(1)
    result["alias"] = alias
    result["name"] = result.get("Name", result["desktop_id"])
    return result


def _list_launchers() -> list[dict[str, str]]:
    seen: set[str] = set()
    rows: list[dict[str, str]] = []
    for d in _desktop_dirs():
        for p in sorted(d.glob("*.desktop")):
            if p.name in seen:
                continue
            parsed = _parse_desktop(p)
            if parsed is None:
                continue
            seen.add(p.name)
            rows.append(parsed)
    return rows


def _matching_units(alias: str) -> list[str]:
    if not alias:
        return []
    out = []
    needle = alias.lower()
    for u in _list_app_units():
        if needle in u["unit"].lower() or needle in u["unit_unescaped"].lower():
            out.append(u["unit"])
    return out


def _launch_start(desktop_id: str) -> int:
    if desktop_id.endswith(".desktop"):
        desktop_id = desktop_id[: -len(".desktop")]
    return subprocess.call(["gtk-launch", desktop_id])


def _launcher_by_id(desktop_id: str) -> dict[str, str] | None:
    for row in _list_launchers():
        if row["desktop_id"] == desktop_id:
            return row
    return None


def _launch_action(action: str, desktop_id: str) -> int:
    launcher = _launcher_by_id(desktop_id)
    if launcher is None:
        print(f"launcher not found: {desktop_id}", file=sys.stderr)
        return 2

    if action == "start":
        return _launch_start(launcher["desktop_id"])

    if action == "inspect":
        print(f"id:\t{launcher['desktop_id']}")
        print(f"name:\t{launcher['name']}")
        print(f"alias:\t{launcher['alias'] or '-'}")
        print(f"path:\t{launcher['path']}")
        print(f"exec:\t{launcher['Exec']}")
        units = _matching_units(launcher["alias"])
        if units:
            print("units:")
            for unit in units:
                print(f"- {unit}")
        else:
            print("units:\t<none>")
        return 0

    if action == "edit":
        editor = os.environ.get("EDITOR", "vi")
        return subprocess.call([editor, launcher["path"]])

    units = _matching_units(launcher["alias"])
    if not units:
        print(f"no loaded unit matching launcher alias: {launcher['alias'] or '<none>'}", file=sys.stderr)
        return 1

    code = 0
    for unit in units:
        rc = _unit_action(action, unit)
        if rc != 0:
            code = rc
    return code


def _launch_list_tsv() -> str:
    rows = []
    for row in _list_launchers():
        rows.append(
            "\t".join(
                [
                    row["desktop_id"],
                    row["name"],
                    row["alias"] or "-",
                    row["Exec"],
                ]
            )
        )
    return "\n".join(rows) + ("\n" if rows else "")


def _launch_fzf(self_path: str) -> int:
    data = _launch_list_tsv()
    if not data.strip():
        print("no app2unit desktop launchers found", file=sys.stderr)
        return 1

    qself = shlex.quote(self_path)
    cmd = [
        "fzf",
        "--delimiter",
        "\t",
        "--with-nth",
        "1,2,3",
        "--nth",
        "1,2,3",
        "--header",
        "enter start | ctrl-r restart-unit | ctrl-x stop-unit | ctrl-j journal | ctrl-e edit",
        "--preview",
        f"{qself} launch --action inspect " + "{1}",
        "--preview-window",
        "right:60%:wrap",
        "--bind",
        f"enter:execute-silent({qself} launch --action start " + "{1})",
        "--bind",
        f"ctrl-r:execute-silent({qself} launch --action restart " + "{1})",
        "--bind",
        f"ctrl-x:execute-silent({qself} launch --action stop " + "{1})",
        "--bind",
        f"ctrl-j:execute({qself} launch --action journal-pager " + "{1})",
        "--bind",
        f"ctrl-e:execute({qself} launch --action edit " + "{1})",
    ]
    return subprocess.run(cmd, input=data, text=True, check=False).returncode


def main() -> int:
    parser = argparse.ArgumentParser(prog="app2unit-fzf")
    sub = parser.add_subparsers(dest="mode", required=True)

    p_unit = sub.add_parser("unit", help="manage loaded app2unit transient units")
    p_unit.add_argument("--list", action="store_true", help="print tab-separated list")
    p_unit.add_argument("--action", choices=["stop", "restart", "status", "status-pager", "journal-pager"])
    p_unit.add_argument("unit", nargs="?")

    p_launch = sub.add_parser("launch", help="manage app2unit launchers")
    p_launch.add_argument("--list", action="store_true", help="print tab-separated list")
    p_launch.add_argument(
        "--action",
        choices=["start", "stop", "restart", "journal-pager", "inspect", "edit"],
    )
    p_launch.add_argument("desktop_id", nargs="?")

    args = parser.parse_args()

    self_path = str(Path(sys.argv[0]).resolve())

    if args.mode == "unit":
        if args.list:
            sys.stdout.write(_unit_list_tsv())
            return 0
        if args.action and args.unit:
            return _unit_action(args.action, args.unit)
        if not shutil.which("fzf"):
            print("missing required command: fzf", file=sys.stderr)
            return 2
        return _unit_fzf(self_path)

    if args.mode == "launch":
        if args.list:
            sys.stdout.write(_launch_list_tsv())
            return 0
        if args.action and args.desktop_id:
            return _launch_action(args.action, args.desktop_id)
        if not shutil.which("fzf"):
            print("missing required command: fzf", file=sys.stderr)
            return 2
        return _launch_fzf(self_path)

    return 2


if __name__ == "__main__":
    raise SystemExit(main())
