#!/usr/bin/env bash
set -euo pipefail

artifact_repo="${MAIM_WORKFLOW_REPO:-fatb4f/dotfiles}"
artifact_workflow="${MAIM_WORKFLOW_FILE:-build-maim.yml}"
artifact_name="${MAIM_ARTIFACT_NAME:-maim-linux-x86_64}"
cache_root="${XDG_CACHE_HOME:-$HOME/.cache}/kitty-shot-primary"
bundle_root="${cache_root}/${artifact_name}"

ensure_bundle() {
  if command -v maim >/dev/null 2>&1 && command -v slop >/dev/null 2>&1; then
    return 0
  fi

  if [[ -x "${bundle_root}/usr/bin/maim" && -x "${bundle_root}/usr/bin/slop" ]]; then
    export PATH="${bundle_root}/usr/bin:${PATH}"
    return 0
  fi

  if ! command -v gh >/dev/null 2>&1; then
    printf 'maim is not installed and gh is unavailable for the workflow bundle\n' >&2
    return 1
  fi

  mkdir -p "${bundle_root}"
  tmpdir="$(mktemp -d "${cache_root}/.tmp.XXXXXX")"
  trap 'rm -rf "${tmpdir}"' EXIT

  if ! gh run download \
    --repo "${artifact_repo}" \
    --workflow "${artifact_workflow}" \
    --name "${artifact_name}" \
    --dir "${tmpdir}"; then
    printf 'maim workflow bundle not found. Run the build-maim workflow in %s, then retry.\n' "${artifact_repo}" >&2
    return 1
  fi

  tarball="$(find "${tmpdir}" -maxdepth 1 -type f \( -name '*.tar.gz' -o -name '*.tgz' \) | head -n 1)"
  if [[ -z "${tarball}" ]]; then
    printf 'maim workflow bundle downloaded, but no tarball was found inside it\n' >&2
    return 1
  fi

  tar -C "${cache_root}" -xzf "${tarball}"
  export PATH="${bundle_root}/usr/bin:${PATH}"
}

ensure_bundle
maim -s | kitten clipboard -p --wait-for-completion --mime image/png /dev/stdin
