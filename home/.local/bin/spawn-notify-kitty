#!/usr/bin/env bash
set -euo pipefail

TITLE="${1:-Spawn}"
BODY="${2:-Event received}"
APP_NAME="spawn"
ICON="dialog-information"

if command -v kitten >/dev/null 2>&1; then
  # Works best when called from a kitty session; falls back gracefully.
  kitten notify --app-name "$APP_NAME" --icon "$ICON" "$TITLE" "$BODY" || true
fi

if command -v notify-send >/dev/null 2>&1; then
  notify-send "$TITLE" "$BODY" || true
fi
