#!/usr/bin/env sh
set -eu

desktop_id="${1:-stage-kitty.desktop}"
[ "$#" -gt 0 ] && shift

if command -v gtk-launch >/dev/null 2>&1; then
  exec gtk-launch "${desktop_id%.desktop}" "$@"
fi

desktop_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
desktop_path="$desktop_dir/$desktop_id"

[ -r "$desktop_path" ] || {
  printf >&2 'desktop file not found: %s\n' "$desktop_path"
  exit 1
}

exec xdg-open "$desktop_path"
